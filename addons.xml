<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addons>
<addon id="repository.mrgee.kodi" name="MrGee Kodi Repository" version="1.0.0" provider-name="MrGee">
    <extension point="xbmc.addon.repository" name="MrGee Kodi Repository">
        <dir>
            <info compressed="false">https://mrgee-host.github.io/kodi-repository/addons.xml</info>
            <checksum>https://mrgee-host.github.io/kodi-repository/addons.xml.md5</checksum>
            <datadir zip="true">https://mrgee-host.github.io/kodi-repository/</datadir>
            <hashes>false</hashes>
        </dir>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="en_GB">MrGee Kodi Repository</summary>
        <description lang="en_GB">Repository for MrGee Kodi addons.</description>
        <platform>all</platform>
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.jpg</fanart>
        </assets>
    </extension>
</addon>
<addon id="script.library.ratings.scraper" name="Library Ratings Scraper" version="1.3.28" provider-name="MrGee">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
    </requires>
    <extension point="xbmc.python.script" library="default.py">
        <provides>executable</provides>
    </extension>
    <extension point="xbmc.service" library="service.py"/>
    <extension point="xbmc.addon.metadata">
        <summary lang="en_GB">Cache library ratings for Arctic Fuse</summary>
        <summary lang="id_ID">Cache rating library untuk Arctic Fuse</summary>
        <description lang="en_GB">Manual-only library ratings scraper. Uses MDBList first for movies and TV shows, falls back to OMDb and TMDb, uses OMDb/TMDb only for episodes, publishes cached ratings/status/Top 250 properties compatible with TMDbHelper/Arctic Fuse. Version 1.3.28 adds bundled IMDb Top 250 TV Shows and simplified settings.</description>
        <description lang="id_ID">Scraper rating library manual-only. Movie dan TV show memakai MDBList dulu, fallback OMDb dan TMDb; episode hanya OMDb/TMDb. Publish rating/status/Top 250 cache ke property kompatibel TMDbHelper/Arctic Fuse. Versi 1.3.28 menambahkan IMDb Top 250 TV Shows bawaan dan settings disederhanakan.</description>
        <platform>all</platform>
        <license>MIT</license>
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.jpg</fanart>
        </assets>
    </extension>
</addon>
</addons>